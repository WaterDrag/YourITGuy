rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Obsah stránky — čtou všichni, píše jen admin
    match /siteContent/{doc} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == 'zitkatomik007@gmail.com';
    }

    // Poptávky — vytvořit může kdokoli, číst/upravit jen admin
    match /inquiries/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null
                                  && request.auth.token.email == 'zitkatomik007@gmail.com';
    }
  }
}
